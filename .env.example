# Copy to .env and adjust. docker-compose reads JWT_SECRET from here.

# PostgreSQL DSN. For local (non-compose) runs against the compose DB:
DATABASE_URL=postgres://porque:porque@localhost:5432/porque?sslmode=disable

# Required. Signing secret for admin JWTs. Generate a strong random value.
JWT_SECRET=dev-insecure-change-me

# API server listen port.
API_PORT=8080

# Default Minecraft server image (itzg handles version downloads + RCON).
MC_DEFAULT_IMAGE=itzg/minecraft-server

# Optional override for the Docker endpoint. Leave empty to use the default
# unix socket / Docker Desktop named pipe.
# DOCKER_HOST=

# Optional host bind-mount root for server data. Leave empty to use Docker
# named volumes (recommended, and required for reliable Windows + docker.sock).
# PORQUE_DATA_ROOT=

# Optional: seed an initial admin user on first boot (no users present).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Backups.
BACKUP_ROOT=/backups
BACKUP_KEEP=5
HELPER_IMAGE=alpine:3.20

# Playit.gg tunnel agent image.
PLAYIT_AGENT_IMAGE=ghcr.io/playit-cloud/playit-agent:latest

# Worker tuning (Go duration strings, e.g. 5s, 2m, 10m).
METRICS_INTERVAL=10s   # heartbeat + metrics sampling period
STARTUP_GRACE=120s     # grace before heartbeat failures count (boot time)
HEARTBEAT_MISSES=3     # consecutive unhealthy checks before recovery
MAX_RESTARTS=5         # max auto-restarts per window before 'corrupted'
RESTART_WINDOW=10m     # sliding window for restart rate limiting
RESTART_BACKOFF=5s     # base backoff before an auto-restart
